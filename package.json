{
	"name": "berp-stack",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"typescript": "~6.0.2",
			"@types/bun": "^1.3.14",
			"@types/node": "^26.1.0",
			"zod": "^4.1.0",
			"elysia": "^1.4.29"
		}
	},
	"scripts": {
		"dev": "bun --filter '*' dev",
		"dev:web": "bun --filter '@berp/web' dev",
		"build": "bun --filter '*' build",
		"build:web": "bun --filter '@berp/web' build",
		"preview:web": "bun --filter '@berp/web' preview",
		"db:generate": "bun --filter '@berp/server' db:generate",
		"db:migrate": "bun --filter '@berp/server' db:migrate",
		"db:push": "bun --filter '@berp/server' db:push",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"test": "bun --filter '*' test",
		"typecheck": "bun --filter '*' typecheck"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@types/bun": "catalog:",
		"@types/node": "catalog:",
		"typescript": "catalog:"
	}
}
