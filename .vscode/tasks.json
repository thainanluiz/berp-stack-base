{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "dev",
			"type": "shell",
			"command": "bun run dev",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "build",
			"type": "shell",
			"command": "bun run build",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": []
		},
		{
			"label": "check",
			"type": "shell",
			"command": "bun run check",
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"problemMatcher": []
		},
		{
			"label": "check:fix",
			"type": "shell",
			"command": "bun run check:fix",
			"problemMatcher": []
		},
		{
			"label": "typecheck",
			"type": "shell",
			"command": "bun run typecheck",
			"problemMatcher": ["$tsc"]
		},
		{
			"label": "db:generate",
			"type": "shell",
			"command": "bun run db:generate",
			"problemMatcher": []
		},
		{
			"label": "db:migrate",
			"type": "shell",
			"command": "bun run db:migrate",
			"problemMatcher": []
		},
		{
			"label": "db:push",
			"type": "shell",
			"command": "bun run db:push",
			"problemMatcher": []
		}
	]
}
