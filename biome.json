{
	"$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "main"
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!**/node_modules",
			"!**/dist",
			"!**/build",
			"!**/public",
			"!**/migrations",
			"!**/*.tsbuildinfo",
			"!bun.lock"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 120,
		"lineEnding": "lf",
		"bracketSameLine": true
	},
	"linter": {
		"enabled": true,
		"domains": {
			"react": "recommended",
			"drizzle": "recommended",
			"test": "recommended"
		},
		"rules": {
			"preset": "recommended",
			"complexity": {
				"noForEach": "error",
				"noImplicitCoercions": "error",
				"noUselessStringConcat": "error",
				"useArrowFunction": "warn"
			},
			"correctness": {
				"noUnusedImports": { "level": "error", "fix": "safe" },
				"noUnusedVariables": "error",
				"useExhaustiveDependencies": "error"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noConsole": {
					"level": "warn",
					"options": {
						"allow": ["warn", "error", "info"]
					}
				}
			},
			"style": {
				"useConst": "error",
				"useImportType": "error",
				"noNonNullAssertion": "warn",
				"useComponentExportOnlyModules": {
					"level": "error",
					"options": {
						"allowConstantExport": true
					}
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
